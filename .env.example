# Your workspace subdomain — the prefix of your user.com URL.
# Example: if you log in at https://acme.user.com, set USERCOM_SUBDOMAIN=acme
USERCOM_SUBDOMAIN=

# Public API token, generated in:
#   Panel → Settings → Workspace settings → API & Integrations → Public API
# Keep this secret. Do NOT commit your real token.
USERCOM_TOKEN=

# Optional: throttle between requests (milliseconds).
# user.com docs say 10 req/s, but sustained bursts can trip a short auth-rejection
# window. Default of 150ms (~6 req/s) is conservative and works reliably.
# USERCOM_THROTTLE_MS=150
